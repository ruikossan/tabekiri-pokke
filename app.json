{
  "expo": {
    "name": "たべきりポッケ",
    "slug": "tabekiri-pokke",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F7FCFF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tabekiripokke.app",
      "buildNumber": "20",
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "食品のバーコード読み取りや写真登録のため、必要なときだけカメラを使用します。撮影した写真は食品管理のためにアプリ内で保存されます。",
        "NSPhotoLibraryUsageDescription": "食品の写真を登録するため、選択した写真だけを読み込みます。フォトライブラリ全体を自動で読み取ることはありません。",
        "NSPhotoLibraryAddUsageDescription": "食品の写真を登録するため、選択した写真だけをアプリ内で利用します。"
      }
    },
    "android": {
      "package": "com.tabekiripokke.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0EA5E9"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "食品のバーコード読み取りや写真登録のため、必要なときだけカメラを使用します。撮影した写真は食品管理のためにアプリ内で保存されます。"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "食品の写真を登録するため、選択した写真だけを読み込みます。フォトライブラリ全体を自動で読み取ることはありません。",
          "cameraPermission": "食品の写真を撮影するため、必要なときだけカメラを使用します。撮影した写真は食品管理のためにアプリ内で保存されます。"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0EA5E9",
          "defaultChannel": "food-expiry"
        }
      ],
      "expo-iap",
      "./plugins/with-ios-supported-platforms-fix",
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-4658426326063416~9486369129"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "e8161601-6762-4227-b2fc-81347a9848a6"
      }
    },
    "owner": "ruikossan"
  }
}
